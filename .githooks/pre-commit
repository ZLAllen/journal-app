#!/bin/sh
# This hook is stored in .githooks/ and only runs when Git is configured to use it.
# Enable it for this clone with: git config core.hooksPath .githooks
set -e

repo_root=$(git rev-parse --show-toplevel)

echo "Running cargo fmt --all -- --check in src-tauri..."
cd "$repo_root/src-tauri"
cargo fmt --all -- --check
